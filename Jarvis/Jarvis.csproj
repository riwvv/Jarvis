    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.6" />
    <PackageReference Include="Microsoft.SemanticKernel" Version="1.74.0" />
    <PackageReference Include="Microsoft.SemanticKernel.Core" Version="1.74.0" />
    <PackageReference Include="NAudio" Version="2.3.0" />
    <PackageReference Include="Porcupine" Version="4.0.2" />
    <PackageReference Include="SileroVad" Version="1.3.0" />
  </ItemGroup>

</Project>